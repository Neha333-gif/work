import mlflow.sklearn 
import pandas as pd 
import numpy as np 

app = Flask(__name__)

## just to create  instance of flask 

model = mlflow.sklearn.load_model("runs:/205e786619784992a0a61d36c0d9b367/model")

@app.route('/api/prediction', methods = ['POST'])
def predict():
    data = request.json 
    df = pd.DataFrame([data])


    prob = model.predict_proba(df)[0][1]
    pred = ["Yes" if prob < 0.5 else "No"]

    return jsonify ({
        "churn_probablities" : (round(prob,4)),
        "churn_predictions" : pred
    })

@app.route('/api/bulkprediction', methods = ["POST"])
def bulk_predict():
    data = request.json['data']
    df = pd.DataFrame(data)

    probs = model.predict_proba(df)[0][1]
    preds = ["Yes" if p > 0.5 else "No" for p in probs]

    return jsonify({
        "churn_probablities" : [round(p, 4) for p in probs],
        "churn_predictions" : preds
    })


