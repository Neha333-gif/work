import numpy as np
import pandas as pd 
import mlflow.catboost
from sklearn.model_selection import train_test_split 
from catboost import CatBoostClassifier
from sklearn.metrics import accuracy_score 
import mlflow

# Force local file-based tracking (no server needed, no errors)
mlflow.set_tracking_uri("")  # Empty string = default local ./mlruns
# Or explicitly: mlflow.set_tracking_uri("file:///c:/path/to/mlruns") if you want a custom folder

# Optional: Create/organize under a specific experiment
mlflow.set_experiment("CatBoost_Telco_Churn")

df = pd.read_csv(r"C:\Users\peepl\Downloads\tele_churn_prediction_api\WA_Fn-UseC_-Telco-Customer-Churn.csv")
df['TotalCharges'] = pd.to_numeric(df['TotalCharges'], errors = 'coerce')
df.dropna(inplace = True)
df.drop('customerID', axis = 1, inplace = True)

df['Churn'] = df['Churn'].map({"Yes": 1, "No": 0})

x = df.drop('Churn', axis = 1)
y = df['Churn']

categorical_cols = x.select_dtypes(include = 'object').columns.tolist()

model = CatBoostClassifier(
    iterations = 200,
    depth = 8,
    learning_rate = 0.1, 
    subsample = 0.8,
    colsample_bylevel = 0.8,
    thread_count = -1,
    random_seed = 42,
    eval_metric = 'Logloss',
    verbose = True
)


x_train, x_test, y_train, y_test = train_test_split(x, y, test_size = 0.2, stratify = y)


with mlflow.start_run(run_name = "catBoostClassifier"):
    model.fit(x_train, y_train, cat_features = categorical_cols)
    y_pred = model.predict(x_test)

    accuracy = accuracy_score(y_test, y_pred)

    mlflow.log_metric('accuracy', accuracy)
    mlflow.catboost.log_model(model, 'model')

    print("mlflow run logged succesfully ")


# api 

from flask import Flask, request, jsonify 
import mlflow.catboost
import pandas as pd 
import numpy as np 

app = Flask(__name__)

model = mlflow.catboost.load_model("runs:/765c780ff1704f758fe9a0ec217ad7fd/model")

@app.route('/api/prediction', methods = ['POST'])
def predict():
    data = request.json 
    df = pd.DataFrame([data])
    prob = float(model.predict_proba(df)[0][1])
    pred = "yes" if prob > 0.5 else "No"
    return jsonify({
        "churn probablity" : round(prob, 4),
        "churn" : pred
    })

@app.route('/api/bulkprediction', methods = ["POST"])
def bulk_predict():
    data = request.json['data']
    df = pd.DataFrame(data)
    prob = model.predict_proba(df)[:, 1]
    pred = ["yes" if p> 0.5 else "No" for p in prob]
    return jsonify ({
        "churn_probablities" : [round(p,4) for p in prob.tolist()],
        "churn_predictions" : pred
    })

@app.route('/ping', methods = ["GET"])
def ping():
    return "CatBoostClassifier API is alive!", 200

if __name__ == '__main__':
    app.run(port = 5001, debug = True)
